rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // One document per account holding the public profile (email, display
    // name, photo URL). A user may only ever touch their own document.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasAll(['email', 'createdAt']);
      allow update: if isOwner(userId);
      // Account deletion goes through the `deleteAccount` Cloud Function, which
      // uses the Admin SDK and bypasses these rules. Clients cannot self-delete
      // their profile doc directly (keeps cleanup atomic across Auth/Storage).
      allow delete: if false;

      // Calculator state — the synced subjects / semesters / settings. Stored
      // as a subcollection (one doc, `calculator/state`) so the profile doc
      // stays small and the snapshot listener only watches what it needs.
      match /calculator/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Private leaderboard settings (opt-in flag + assigned handle). The owner
      // may read their own; only the Cloud Functions (Admin SDK) may write, so
      // the handle and participation state can't be tampered with client-side.
      match /leaderboard/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // Public overall (cumulative) leaderboard projection. Readable by any
    // signed-in user; written exclusively by the Cloud Functions (Admin SDK).
    // The doc id is an anonymous handle, so no uid/email is ever exposed here.
    match /leaderboard/{handle} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Public per-term (per-semester) leaderboard projections, one doc per
    // student per term. Same read/write policy as the overall board.
    match /leaderboardSemesters/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Anonymous-handle reservations. Server-only registry that guarantees handle
    // uniqueness; clients get nothing.
    match /leaderboardHandles/{handle} {
      allow read, write: if false;
    }

    // Rate-limit buckets for the auth Cloud Functions. Server-only — written
    // exclusively by the Admin SDK (which bypasses rules); clients get nothing.
    match /rateLimits/{bucketId} {
      allow read, write: if false;
    }

    // Default deny — everything not explicitly matched above is private.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

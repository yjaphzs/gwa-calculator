# Email sending via Resend (https://resend.com/docs/send-with-nodejs).
# Copy to functions/.env for local emulator use. In CI these are injected from
# GitHub secrets/vars by deploy.yml.
#
# Setup:
#   1. Create a Resend account and add your domain (yjaphzs.xyz), then add the
#      DKIM/SPF DNS records Resend shows you in Namecheap (Advanced DNS).
#   2. Once the domain is "Verified", create an API key.
#   3. Set EMAIL_FROM_EMAIL to any address on the verified domain (e.g.
#      no-reply@yjaphzs.xyz). Until the domain is verified you can only use
#      onboarding@resend.dev (delivers to your own account email).
RESEND_API_KEY=
EMAIL_FROM_NAME=GWA Calculator
EMAIL_FROM_EMAIL=no-reply@yjaphzs.xyz

# App context used inside emails (action links + copy).
APP_URL=http://localhost:3000
APP_NAME=GWA Calculator
FUNCTIONS_ENV=development
